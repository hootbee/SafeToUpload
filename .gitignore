# macOS / editor
.DS_Store
.vscode/
.idea/

# Environment files
.env
.env.*
!.env.example

# Logs
*.log
logs/

# Frontend (Vite + React)
frontend/node_modules/
frontend/dist/
frontend/dist-ssr/
frontend/.vite/
frontend/*.local

# Server (placeholder / future Nest.js)
server/node_modules/
server/dist/
server/src/_shared/
server/coverage/
server/.nestjs-cli.json

# Generic
coverage/
.tmp/
tmp/

# Prevent compiled artifacts in shared TS source trees
shared/**/*.js
shared/**/*.js.map
shared/**/*.d.ts
server/src/_shared/**/*.js
server/src/_shared/**/*.js.map
server/src/_shared/**/*.d.ts

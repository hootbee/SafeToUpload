VITE_API_BASE_URL=http://localhost:3270
# 로컬 WebGPU: Transformers.js ONNX (공식 weights: google/gemma-4-E4B-it)
VITE_LOCAL_MODEL_ID=onnx-community/gemma-4-E4B-it-ONNX
VITE_SERVER_MODEL_ID=gemma-4-26b
# Hugging Face Read 토큰 (게이트/다운로드 오류 시, git 제외)
# VITE_HF_TOKEN=hf_xxxxxxxx
# 마스킹 영역 자동 탐지 (zero-shot object detection)
# VITE_DETECT_MODEL_ID=Xenova/owlvit-base-patch32
# VITE_DETECT_THRESHOLD=0.08
# 마스킹 강도 (숫자·간판 가독성 차단)
# VITE_MASK_BLUR_RADIUS=200
# VITE_MASK_BLUR_PASSES=10
# VITE_MASK_PIXELATE_MAX_PX=2
# VITE_MASK_PIXELATE_ROUNDS=12
# VITE_MASK_FEATHER_PX=24
# VITE_MASK_OVERLAY_OPACITY=0

# =========================================================
# Base
# =========================================================
PORT=3270
APP_MODE=development-server
UPLOAD_DIR="./uploads/images"
TEMP_DIR="./storage/temp"
AI_SERVER_URL="http://localhost:8000"
AI_SERVER_MODEL="gemma-4-26b"
# Open WebUI / OpenAI 호환 Chat Completions (서버 모드 기본)
AI_LLM_CHAT_URL="https://macmini.tail729089.ts.net:8443/api/chat/completions"
AI_LLM_API_KEY=
AI_LLM_MODEL="gemma4:26b"
# LLM 응답 대기(ms). 26B·Tailscale 원격은 600000(10분) 권장
AI_LLM_TIMEOUT_MS=600000
AI_LLM_MAX_TOKENS=1024
AI_SERVER_TIMEOUT_MS=600000
# true면 AI 서버 장애 시 mockAnalyze로 폴백 (개발용)
AI_USE_MOCK_FALLBACK=false
PERSIST_RAW_INPUT=true

# CORS
# 운영에서는 제한 권장, 개발 임시 전체허용은 main.ts에서 origin:true 사용
CORS_ORIGIN="http://localhost:5173,chrome-extension://YOUR_EXTENSION_ID"

# =========================================================
# A) Server 운영 기본 (API 컨테이너 + Postgres 컨테이너)
# docker compose up -d --build
# =========================================================
# compose에서 DATABASE_URL을 postgres 호스트로 주입하므로
# 아래 값은 참고/백업용
DATABASE_URL="postgresql://privacy_user:privacy_password@postgres:5432/privacy_check?schema=public"

# =========================================================
# B) 백엔드/AI 로컬 개발 (Node 프로세스 로컬 실행 + 로컬/컨테이너 DB)
# npm run start:dev
# =========================================================
# 로컬 Node 프로세스에서 Postgres 접근 시 사용 (localhost)
# DATABASE_URL="postgresql://privacy_user:privacy_password@localhost:5432/privacy_check?schema=public"

# =========================================================
# C) Local 모드 전환 후보 (SQLite)
# =========================================================
LOCAL_DATABASE_URL="file:./local.db"

{
  "compilerOptions": {
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "resolvePackageJsonExports": true,
    "esModuleInterop": true,
    "isolatedModules": true,
    "declaration": true,
    "removeComments": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "target": "ES2023",
    "sourceMap": true,
    "outDir": "./dist",
    "baseUrl": "./",
    "paths": {
      "@shared/risk-scoring": ["src/_shared/risk-scoring/index"],
      "@shared/risk-scoring/*": ["src/_shared/risk-scoring/*"],
      "@shared/privacy-memory": ["src/_shared/privacy-memory/index"],
      "@shared/privacy-memory/*": ["src/_shared/privacy-memory/*"],
      "@shared/analysis-prompt-schema": ["src/_shared/analysis-prompt-schema"],
      "@shared/prompts": ["src/_shared/prompts/index.ts"],
      "@shared/prompts/*": ["src/_shared/prompts/*"]
    },
    "incremental": true,
    "skipLibCheck": true,
    "strictNullChecks": true,
    "forceConsistentCasingInFileNames": true,
    "noImplicitAny": false,
    "strictBindCallApply": false,
    "noFallthroughCasesInSwitch": false
  }
}

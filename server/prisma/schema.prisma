generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model AnalysisRecord {
  id             String          @id @default(cuid())
  sourceType     String
  platform       String
  inferenceMode  String          @default("local")
  pageUrl        String?
  pageDomain     String?
  inputText      String?
  imagePath      String?
  status         String
  riskScore  Int?
  riskLevel  String?
  summary    String?
  piiTypes   Json?
  piiCount   Int?
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt
  result     AnalysisResult?
}

model AnalysisResult {
  id                String         @id @default(cuid())
  analysisId        String         @unique
  analysis          AnalysisRecord @relation(fields: [analysisId], references: [id], onDelete: Cascade)
  piiItems          Json?
  exifItems         Json?
  imageRisks        Json?
  contextResult     Json?
  rewriteSuggestion String?
  rawAiResponse     Json?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
}

model UserSetting {
  id                           String   @id @default(cuid())
  targetPlatforms              Json
  inferenceMode                String   @default("local")
  sensitivity                  Int
  retentionDays                Int
  notificationEnabled          Boolean
  privacyMemoryEnabled         Boolean  @default(true)
  privacyMemoryRetentionDays   Int      @default(90)
  privacyMemoryUseForBlocking    Boolean  @default(false)
  privacyMemoryUseForScoreBoost  Boolean  @default(true)
  createdAt                    DateTime @default(now())
  updatedAt                    DateTime @updatedAt
}

model PrivacyMemoryProfile {
  id                String    @id @default(cuid())
  userId            String    @default("default")
  memoryType        String    @default("privacy_context")
  piiTypes          Json
  contextTags       Json
  riskyCombinations Json
  sourceTypes       Json?
  seenCount         Int       @default(1)
  riskWeight        Float     @default(0.5)
  confidence        Float     @default(0.5)
  lastRiskLevel     String?
  lastRiskScoreBand String?
  firstSeenAt       DateTime  @default(now())
  lastSeenAt        DateTime  @default(now())
  expiresAt         DateTime?
  isActive          Boolean   @default(true)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([userId, isActive])
}
